<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Warn"
      internalLogToConsole="true">

  <extensions>
    <add assembly="NLog.Web.AspNetCore" />
  </extensions>

  <!-- Override with the LOG_DIRECTORY env var in containers (mount a volume there). -->
  <variable name="logDirectory" value="${environment:LOG_DIRECTORY:whenEmpty=${basedir}/logs}" />

  <variable name="exceptionDetail"
            value="${exception:format=type,message,method:maxInnerExceptionLevel=10:innerFormat=type,message,method:separator=\r\n}" />

  <targets async="true">

    <!-- Machine-readable structured JSON, one object per line. The date in the file
         name rolls the log daily; maxArchiveDays prunes files older than 30 days. -->
    <target name="jsonFile" xsi:type="File"
            fileName="${logDirectory}/ecommerce-${shortdate}.log"
            maxArchiveDays="30"
            keepFileOpen="true"
            encoding="utf-8">
      <layout xsi:type="JsonLayout" includeEventProperties="true" includeScopeProperties="true">
        <attribute name="timestamp" layout="${date:universalTime=true:format=o}" />
        <attribute name="level" layout="${level:upperCase=true}" />
        <attribute name="correlationId" layout="${scopeproperty:item=CorrelationId:whenEmpty=${event-properties:item=CorrelationId}}" />
        <attribute name="logger" layout="${logger}" />
        <attribute name="message" layout="${message}" />
        <attribute name="requestMethod" layout="${aspnet-request-method}" />
        <attribute name="requestUrl" layout="${aspnet-request-url:includeQueryString=false}" />
        <attribute name="requestIp" layout="${aspnet-request-ip}" />
        <attribute name="userNetId" layout="${aspnet-user-claim:ClaimType=NetId}" />
        <attribute name="action" layout="${aspnet-mvc-controller}/${aspnet-mvc-action}" />
        <attribute name="exceptionType" layout="${exception:format=type}" />
        <attribute name="exception" layout="${exceptionDetail}" />
        <attribute name="stackTrace" layout="${exception:format=stacktrace}" />
      </layout>
    </target>

    <!-- Human-readable console for dev / docker logs. -->
    <target name="console" xsi:type="ColoredConsole"
            layout="${date:format=HH\:mm\:ss.fff} ${level:uppercase=true:padding=-5} [${scopeproperty:item=CorrelationId:whenEmpty=--------}] ${logger:shortName=true} | ${message} ${onexception:${newline}${exceptionDetail}${newline}${exception:format=stacktrace}}" />

  </targets>

  <rules>
    <!-- Quieten framework noise; keep warnings and above. -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />
    <logger name="Microsoft.Hosting.Lifetime*" minlevel="Info" writeTo="console" final="true" />

    <logger name="*" minlevel="Info" writeTo="jsonFile,console" />
  </rules>
</nlog>
